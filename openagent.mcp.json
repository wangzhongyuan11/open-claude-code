{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "mcp-server-filesystem",
      "args": ["{workspace}/work"],
      "enabled": true,
      "timeout": 30
    },
    "git": {
      "type": "stdio",
      "command": "mcp-git",
      "enabled": true,
      "timeout": 30
    },
    "everything": {
      "type": "stdio",
      "command": "mcp-server-everything",
      "enabled": true,
      "timeout": 30
    },
    "memory": {
      "type": "stdio",
      "command": "mcp-server-memory",
      "enabled": true,
      "timeout": 30
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "mcp-server-sequential-thinking",
      "enabled": true,
      "timeout": 30
    }
  }
}
